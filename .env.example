# App
APP_NAME=AI Trading Chatbot
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# Local fallback works without this value. Use PostgreSQL for production.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tradingbot

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Broker / market data
DEFAULT_CRYPTO_EXCHANGE=kraken
DEFAULT_WATCHLIST=BTC/USDT,ETH/USDT,SOL/USDT,AAPL,TSLA,QQQ
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Risk
ACCOUNT_EQUITY=10000
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MINIMUM_RR=2
SIGNAL_REFRESH_SECONDS=20

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
